rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default catch-all deny rule for safety
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection: Allow read and write for profiles
    match /users/{userId} {
      allow read, write: if true;
    }

    // Products collection: Allow public read and write (supports unauthenticated seeding and admin CRUD operations)
    match /products/{productId} {
      allow read, write: if true;
    }

    // Reviews collection: Allow public read and write (supports comments and reviews)
    match /reviews/{reviewId} {
      allow read, write: if true;
    }
  }
}
