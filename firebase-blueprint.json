{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile in the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "E-commerce product item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "price", "description", "image", "stock", "category"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review left by a user",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["productId", "userName", "userEmail", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stored user profile information"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "E-commerce catalog products"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product ratings and reviews"
    }
  }
}
